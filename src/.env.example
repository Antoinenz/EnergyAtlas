# Copy to .env and fill in.
#
# Local dev (after `npx supabase start` from the repo root):
#   run `npx supabase status` and copy the "API URL" and "anon key" values.
#   The anon key for local dev is a fixed, publicly-documented JWT -- it is
#   not a secret, it only works against your own local stack.
#
# Hosted project: Settings -> API in the Supabase dashboard.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=
